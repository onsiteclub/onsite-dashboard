# Auth Hub
NEXT_PUBLIC_AUTH_HUB_URL=https://auth.onsiteclub.ca

# App URLs
NEXT_PUBLIC_APP_URL=https://member.onsiteclub.ca
NEXT_PUBLIC_CALCULATOR_URL=https://calc.onsite.ca
NEXT_PUBLIC_SHOP_URL=https://shop.onsiteclub.ca
NEXT_PUBLIC_LEARN_URL=https://learn.onsiteclub.ca
